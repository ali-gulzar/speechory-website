---
// Hero — static, ships 0 KB JS. The "live call" waveform is pure CSS.
const bars = Array.from({ length: 34 });
---

<header class="relative z-10">
  <nav class="mx-auto flex max-w-6xl items-center justify-center px-6 py-7">
    <a href="#top" class="flex items-center gap-3">
      <span
        class="grid h-11 w-11 place-items-center rounded-2xl bg-ink"
        aria-hidden="true"
      >
        <svg width="24" height="24" viewBox="0 0 64 64" fill="none">
          <g fill="#DCEC4E">
            <rect x="8" y="25" width="7" height="14" rx="3.5"></rect>
            <rect x="18" y="18" width="7" height="28" rx="3.5"></rect>
            <rect x="28" y="11" width="7" height="42" rx="3.5"></rect>
            <rect x="38" y="19" width="7" height="26" rx="3.5"></rect>
            <rect x="48" y="26" width="7" height="12" rx="3.5"></rect>
          </g>
        </svg>
      </span>
      <span class="font-brand text-[2.15rem] font-bold tracking-[-0.02em]"
        >Speechory</span
      >
    </a>
  </nav>
</header>

<section id="top" class="relative z-10">
  <div
    class="mx-auto grid max-w-6xl items-center gap-x-12 gap-y-14 px-6 pt-10 pb-20 lg:grid-cols-[1.22fr_1fr] lg:pt-16 lg:pb-28"
  >
    <!-- Left: the pitch -->
    <div class="max-w-xl">
      <span
        class="reveal reveal-1 inline-flex items-center gap-2 rounded-full border border-hairline bg-surface px-3.5 py-1.5 text-[0.7rem] font-medium tracking-[0.18em] text-muted uppercase"
      >
        AI Voice Receptionist &middot; Dental &amp; Medical
      </span>

      <h1
        class="reveal reveal-2 mt-6 text-balance text-[clamp(2.4rem,5.6vw,4.4rem)] leading-[1.04] font-medium"
      >
        The call you miss <span class="highlight">after hours</span> is someone
        else&rsquo;s patient by morning.
      </h1>

      <p
        class="reveal reveal-3 mt-6 max-w-md text-[1.075rem] leading-relaxed text-muted"
      >
        Speechory answers every call 24/7, books the appointment while the
        patient is still on the line, and hands you a clean schedule each
        morning. No voicemail. No missed bookings. No new hire.
      </p>

      <div class="reveal reveal-3 mt-8">
        <a
          href="#estimator"
          class="group inline-flex items-center gap-2 rounded-full bg-lime px-6 py-3.5 font-medium text-text shadow-[0_1px_2px_rgba(25,19,20,0.12)] transition hover:-translate-y-0.5 hover:bg-lime-bright"
        >
          See what you&rsquo;re missing
          <span
            class="transition-transform group-hover:translate-x-0.5"
            aria-hidden="true">&rarr;</span
          >
        </a>
      </div>

      <p
        class="reveal reveal-4 mt-8 flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-muted"
      >
        <span>HIPAA compliant</span>
        <span class="text-muted/40" aria-hidden="true">&bull;</span>
        <span>SOC 2 compliant</span>
        <span class="text-muted/40" aria-hidden="true">&bull;</span>
        <span>24/7 available</span>
      </p>
    </div>

    <!-- Right: dark "phone" call-card on a lime block (thesis object) -->
    <div class="reveal reveal-4">
      <div
        class="rounded-[2rem] bg-lime p-4 shadow-[0_30px_70px_-40px_rgba(25,19,20,0.4)] sm:p-6"
      >
        <div class="phone p-6">
          <div class="flex items-center justify-between">
            <span
              class="inline-flex items-center gap-2 text-sm font-medium text-good"
            >
              <span class="live-dot"></span>
              Live &middot; answering 24/7
            </span>
            <span class="tnum text-sm text-white/45">11:42 PM</span>
          </div>

          <div class="mt-5 flex items-center justify-between text-sm">
            <span class="text-white/45">Incoming call</span>
            <span class="text-white/45">After hours</span>
          </div>

          <!-- pure-CSS equalizer waveform -->
          <div class="eq mt-3" role="img" aria-label="Live voice waveform">
            {
              bars.map((_, i) => (
                <span style={`animation-delay:${(((i * 7) % 13) - 6) * 0.11}s`} />
              ))
            }
          </div>

          <!-- faux transcript -->
          <div class="mt-6 space-y-3">
            <div
              class="max-w-[88%] rounded-2xl rounded-tl-md bg-white/10 px-4 py-2.5 text-sm text-white/90"
            >
              &ldquo;Hi, I&rsquo;d like to book an appointment for a teeth
              filling on Thursday.&rdquo;
            </div>
            <div
              class="ml-auto max-w-[88%] rounded-2xl rounded-tr-md bg-lime px-4 py-2.5 text-sm text-text"
            >
              &ldquo;Of course &mdash; I can get you in Thursday at 10:15 AM.
              Shall I book it?&rdquo;
            </div>
          </div>

          <div
            class="mt-5 flex items-center gap-2 border-t border-white/10 pt-4 text-sm"
          >
            <span
              class="grid h-5 w-5 place-items-center rounded-full bg-good text-[0.7rem] text-[#06231a]"
              aria-hidden="true">&#10003;</span
            >
            <span class="text-white/90">Appointment booked</span>
            <span class="text-white/45">&middot; confirmation texted</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
