---
interface Props {
  title: string;
  description: string;
  /** Path to a social share image in /public, e.g. "/og-image.png". Optional. */
  image?: string;
}

const { title, description, image } = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url).href;
const ogImage = image ? new URL(image, Astro.site ?? Astro.url).href : undefined;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "Speechory",
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web",
  description:
    "AI voice agent receptionist for dental and medical practices. Answers every call 24/7 and books appointments automatically.",
  audience: {
    "@type": "Audience",
    audienceType: "Dental and medical practices",
  },
  offers: {
    "@type": "Offer",
    category: "AI receptionist / answering service",
  },
};
---

<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:site_name" content="Speechory" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
{ogImage && <meta property="og:image" content={ogImage} />}

<!-- Twitter -->
<meta name="twitter:card" content={ogImage ? "summary_large_image" : "summary"} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
{ogImage && <meta name="twitter:image" content={ogImage} />}

<meta name="theme-color" content="#0C0A12" />

<script
  type="application/ld+json"
  set:html={JSON.stringify(jsonLd)}
/>
