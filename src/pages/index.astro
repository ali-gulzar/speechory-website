---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import EstimatorSection from "../components/EstimatorSection.astro";
---

<BaseLayout>
  <main>
    <Hero />
    <EstimatorSection />
  </main>

  <footer class="relative z-10 border-t border-hairline">
    <div
      class="mx-auto flex max-w-6xl flex-col items-start justify-between gap-4 px-6 py-8 text-sm text-muted sm:flex-row sm:items-center"
    >
      <span class="flex items-center gap-2">
        <span class="font-medium text-text">Speechory</span>
        <span class="text-hairline" aria-hidden="true">&bull;</span>
        AI voice receptionist for practices
      </span>
      <span>&copy; {new Date().getFullYear()} Speechory</span>
    </div>
  </footer>
</BaseLayout>
